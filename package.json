{
  "name": "personal-newspaper",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "pnpm run build && node --import ./tests/cloudflare-loader.mjs --test tests/*.test.mjs tests/*.test.ts",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "edition:context": "node skills/personal-newspaper/scripts/snapshot-context.mjs",
    "profile:save": "node skills/personal-newspaper/scripts/save-profile.mjs",
    "edition:prepare": "node skills/personal-newspaper/scripts/prepare-edition.mjs",
    "edition:validate": "node skills/personal-newspaper/scripts/validate-edition.mjs",
    "edition:publish": "node skills/personal-newspaper/scripts/publish-edition.mjs",
    "edition:restore": "node skills/personal-newspaper/scripts/restore-edition.mjs",
    "flow:verify-empty": "node --import ./tests/cloudflare-loader.mjs --test --test-name-pattern='empty first-run pipeline' tests/publish-edition.test.mjs && pnpm skill:validate",
    "skill:validate": "node skills/personal-newspaper/scripts/validate-skill.mjs",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
